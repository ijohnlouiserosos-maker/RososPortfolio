@page "/projects"
@attribute [StreamRendering]

<PageTitle>Projects</PageTitle>

<div class="projects-container">
    <h1>My Projects</h1>

    <p>Here are some of the projects I've worked on.</p>

    @if (projects == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="projects-grid">
            @foreach (var project in projects)
            {
                <div class="project-card">
                    <h3>@project.Name</h3>
                    <p>@project.Description</p>
                    <p><strong>Technologies:</strong> @project.Technologies</p>
                    @if (!string.IsNullOrEmpty(project.Link))
                    {
                        <a href="@project.Link" target="_blank">View Project</a>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private Project[]? projects;

    protected override async Task OnInitializedAsync()
    {
        // Simulate asynchronous loading
        await Task.Delay(500);

        projects = new[]
        {
            new Project
            {
                Name = "Portfolio Website",
                Description = "A personal portfolio website built with Blazor to showcase my skills and projects.",
                Technologies = "Blazor, C#, HTML, CSS",
                Link = "#"
            },
            new Project
            {
                Name = "E-commerce App",
                Description = "A full-stack e-commerce application with user authentication and payment integration.",
                Technologies = "ASP.NET Core, React, SQL Server",
                Link = "https://github.com/example/ecommerce"
            },
            new Project
            {
                Name = "Task Management Tool",
                Description = "A web-based task management application for teams to collaborate and track progress.",
                Technologies = "Vue.js, Node.js, MongoDB",
                Link = "https://github.com/example/taskmanager"
            },
            new Project
            {
                Name = "Data Visualization Dashboard",
                Description = "An interactive dashboard for visualizing sales data with charts and filters.",
                Technologies = "Python, Flask, D3.js, PostgreSQL",
                Link = "https://github.com/example/dashboard"
            }
        };
    }

    private class Project
    {
        public string? Name { get; set; }
        public string? Description { get; set; }
        public string? Technologies { get; set; }
        public string? Link { get; set; }
    }
}
